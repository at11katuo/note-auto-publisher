# ============================================================
# Database
# SQLite ファイルパス (packages/db ディレクトリからの相対パス)
# ============================================================
DATABASE_URL="file:dev.db"

# ============================================================
# Anthropic Claude API
# 取得先: https://console.anthropic.com/
# ============================================================
ANTHROPIC_API_KEY="your_api_key_here"

# ============================================================
# note.com ログイン情報
# ============================================================
NOTE_EMAIL="your@email.com"
NOTE_PASSWORD="your_password_here"

# ============================================================
# 管理画面 Basic 認証
# ============================================================
DASHBOARD_BASIC_USER=admin
DASHBOARD_BASIC_PASS=your_password_here

# ============================================================
# Discord Webhook (エラー通知)
# 取得先: Discord サーバー設定 > 連携サービス > ウェブフック
# ============================================================
DISCORD_WEBHOOK_URL="https://discord.com/api/webhooks/000000000000000000/xxxx"

# ============================================================
# X (Twitter) API v2 Bearer Token (任意)
# 未設定の場合は X からの収集をスキップします
# 取得先: https://developer.twitter.com/en/portal/dashboard
# ============================================================
X_BEARER_TOKEN=""

# ============================================================
# アプリケーション設定
# ============================================================
NODE_ENV="development"
LOG_LEVEL="info"
