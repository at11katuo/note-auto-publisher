{
  "name": "note-auto-publisher",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "concurrently --names collector \"pnpm --filter @note/collector dev\"",
    "build": "pnpm -r build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\" --ignore-path .gitignore",
    "db:migrate": "pnpm --filter @note/db migrate",
    "db:studio": "pnpm --filter @note/db studio",
    "db:generate": "pnpm --filter @note/db generate",
    "db:seed": "pnpm --filter @note/db seed",
    "collect": "pnpm --filter @note/collector start",
    "generate": "pnpm --filter @note/generator start",
    "generate:batch": "pnpm --filter @note/generator start -- --batch 3",
    "publish:run": "pnpm --filter @note/publisher start",
    "publish:login": "pnpm --filter @note/publisher start -- --login-only",
    "test": "pnpm -r --if-present test"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@prisma/client", "@prisma/engines", "esbuild", "prisma"]
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "concurrently": "^9.1.0",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.15.0"
  }
}
